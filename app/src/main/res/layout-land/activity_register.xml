<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.fungsitama.dhsshopee.activity.login.RegisterActivity"
    >


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="10dp"
        android:layout_gravity="center_horizontal"
        >


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="0.2"
            android:orientation="vertical"
            android:gravity="center"
            >

            <ImageView
                android:id="@+id/logo"
                android:layout_width="150dp"
                android:layout_height="60dp"
                android:background="@drawable/logo_kisel"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title_pendaftaran_akun"
                    android:textColor="#292828"
                    android:textSize="25dp"
                    android:gravity="center"
                    android:fontFamily="@font/roboto_bold"
                    />

                <TextView
                    android:id="@+id/txt_SubTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/subtitle_pendaftaran_akun"
                    />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            >

            <LinearLayout
                android:id="@+id/formRegsiter"
                android:layout_below="@+id/ly_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                >

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:layout_marginBottom="7dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="20dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            >

                            <!--Nama-->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingTop="10dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textSize="12dp"
                                    android:text="@string/nama_lengkap"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <EditText
                                    android:id="@+id/et_NamaLengkap"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_smu"
                                    android:drawablePadding="5dp"
                                    android:hint="@string/masukkan_nama_lengkap"
                                    android:inputType="text"
                                    android:textColor="#000"
                                    android:textSize="14dp" />

                            </LinearLayout>

                            <!--Username-->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingTop="10dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textSize="12dp"
                                    android:text="@string/nama_pengguna"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <EditText
                                    android:id="@+id/et_NamaPengguna"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="@string/masukkan_nama_pengguna"
                                    android:textSize="14dp"
                                    android:inputType="text"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:drawableLeft="@drawable/ic_smu"
                                    />

                            </LinearLayout>

                            <!--Kata Sandi-->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingTop="10dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textSize="12dp"
                                    android:text="@string/kata_sandi"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <EditText
                                    android:id="@+id/et_KataSandi"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="@string/masukkan_kata_sandi"
                                    android:textSize="14dp"
                                    android:inputType="textPassword"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:drawableLeft="@drawable/ic_smu"
                                    />

                            </LinearLayout>

                            <!--Email-->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingTop="10dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textSize="12dp"
                                    android:text="@string/email"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <EditText
                                    android:id="@+id/et_Email"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="@string/masukkan_email"
                                    android:textSize="14dp"
                                    android:inputType="textEmailSubject"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:drawableLeft="@drawable/ic_smu"
                                    />

                            </LinearLayout>

                            <!--No Hp-->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingTop="10dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textSize="12dp"
                                    android:text="@string/nomor_hp"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <EditText
                                    android:id="@+id/et_NomorHp"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="@string/masukkan_nomor_hp"
                                    android:textSize="14dp"
                                    android:inputType="number"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:drawableLeft="@drawable/ic_smu"
                                    />

                            </LinearLayout>



                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                >

                                <Button
                                    android:id="@+id/btn_Register"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/button_yellow"
                                    android:padding="12dp"
                                    android:text="@string/daftar"
                                    android:layout_marginTop="40dp"
                                    android:textColor="@android:color/white"
                                    android:fontFamily="@font/roboto_bold"
                                    />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:paddingTop="10dp"
                                    android:layout_gravity="center_horizontal"
                                    android:layout_below="@+id/btn_Register"
                                    android:layout_marginBottom="10dp"
                                    >

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginRight="10dp"
                                        android:textSize="12dp"
                                        android:text="@string/sudah_punya_akun"
                                        android:paddingTop="4dp"
                                        android:paddingLeft="5dp"
                                        android:gravity="center"
                                        />

                                    <TextView
                                        android:id="@+id/txt_Login"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:textSize="14dp"
                                        android:text="@string/masuk"
                                        android:paddingTop="4dp"
                                        android:paddingLeft="5dp"
                                        android:fontFamily="@font/roboto_bold"
                                        android:textColor="@color/blues"
                                        android:gravity="center"
                                        />
                                </LinearLayout>

                            </RelativeLayout>




                        </LinearLayout>

                    </androidx.cardview.widget.CardView>


                </androidx.core.widget.NestedScrollView>



            </LinearLayout>


        </LinearLayout>


    </LinearLayout>






</RelativeLayout>