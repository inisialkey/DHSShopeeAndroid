<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.fungsitama.dhsshopee.activity.driver.ORDER.OrderBaruActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_above="@+id/button">

        <LinearLayout
            android:id="@+id/ly_TambahKendaraan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="7dp"
            android:layout_marginRight="7dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="7dp"
                android:layout_marginTop="7dp"
                app:cardCornerRadius="5dp"
                app:cardElevation="5dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="15dp"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:text="@string/pilih_kendaraan"
                            android:textSize="15dp"
                            android:gravity="center|left"
                            android:fontFamily="@font/roboto_bold"
                            android:layout_marginBottom="10dp"
                            />

                        <TextView
                            android:id="@+id/icon_CheklistKendaraan"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:drawableRight="@drawable/ic_chekin"
                            android:textSize="15dp"
                            android:gravity="center|left"
                            android:fontFamily="@font/roboto_bold"
                            android:layout_marginBottom="10dp"
                            android:visibility="gone"
                            />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center_horizontal"
                        >

                        <com.toptoche.searchablespinnerlibrary.SearchableSpinner
                            android:id="@+id/spin_Kendaraan"
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            app:hintText="@string/pilih_kendaraan"
                            android:inputType="text"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:drawableLeft="@drawable/ic_action_name"
                            android:nextFocusDown="@id/et_Koli"
                            android:visibility="visible"
                            />
                        <TextView
                            android:id="@+id/tv_KodeKendaraan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:text="Kode Kendaraan"
                            android:gravity="left"
                            android:textSize="15dp"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:visibility="gone"
                            android:fontFamily="@font/roboto_bold"
                            android:drawableLeft="@drawable/ic_truck"
                            />
                        <EditText
                            android:id="@+id/et_KodeKendaraan"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:hint="Asal"
                            android:paddingStart="20dp"
                            android:textSize="13dp"
                            android:visibility="gone"
                            android:inputType="text"
                            />



                    </LinearLayout>



                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/ly_TambahDO"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:layout_marginLeft="7dp"
                android:layout_marginRight="7dp"
                >

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginBottom="7dp"
                    android:layout_marginTop="7dp"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="5dp"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="15dp"
                        >

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_gravity="center"
                            >

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="3"
                                android:text="@string/tambah_no_do"
                                android:textSize="15dp"
                                android:gravity="center|left"
                                android:fontFamily="@font/roboto_bold"
                                android:layout_marginBottom="10dp"
                                />

                            <TextView
                                android:id="@+id/icon_CheklistNomorDO"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="3"
                                android:drawableRight="@drawable/ic_chekin"
                                android:textSize="15dp"
                                android:gravity="center|left"
                                android:fontFamily="@font/roboto_bold"
                                android:layout_marginBottom="10dp"
                                android:visibility="gone"
                                />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ly_formTambahNomorDO"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="visible">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                >

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginRight="10dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="@string/nomor_do"
                                    android:textSize="10dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:textSize="10dp"
                                    android:text="@string/nomor_kendaraan"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    android:visibility="gone"
                                    />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                android:paddingBottom="10dp"
                                >

                                <EditText
                                    android:id="@+id/et_NoDo"
                                    android:layout_width="0dp"
                                    android:layout_height="40dp"
                                    android:layout_weight="1"
                                    android:hint="@string/hint_nomor_do"
                                    android:layout_marginRight="10dp"
                                    android:textSize="13dp"
                                    android:inputType="text"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:drawableLeft="@drawable/ic_bus"
                                    android:nextFocusDown="@id/spin_Tujuan"
                                    />

                                <EditText
                                    android:id="@+id/et_NoKendaraan"
                                    android:layout_width="0dp"
                                    android:layout_height="40dp"
                                    android:layout_weight="1"
                                    android:hint="@string/hint_nomor_kendaraan"
                                    android:textSize="13dp"
                                    android:inputType="number"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:drawableLeft="@drawable/ic_truck"
                                    android:enabled="false"
                                    android:visibility="gone"
                                    />


                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="10dp"
                                android:text="@string/asal"
                                android:paddingTop="4dp"
                                android:paddingLeft="5dp"
                                />
                            <com.toptoche.searchablespinnerlibrary.SearchableSpinner
                                android:id="@+id/spin_Asal"
                                android:layout_width="match_parent"
                                android:layout_height="30dp"
                                app:hintText="KTRPST - Kantor Pusat"
                                android:inputType="text"
                                android:layout_marginBottom="10dp"
                                android:drawablePadding="5dp"
                                android:textColor="#000"
                                android:drawableLeft="@drawable/ic_action_name"
                                android:nextFocusDown="@id/et_Koli"
                                />
                            <EditText
                                android:id="@+id/et_KodeAsal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text=""
                                android:hint="Asal"
                                android:paddingStart="20dp"
                                android:textSize="13dp"
                                android:visibility="gone"
                                android:inputType="text"
                                />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="10dp"
                                android:text="@string/tujuan"
                                android:paddingTop="4dp"
                                android:paddingLeft="5dp"
                                />
                            <com.toptoche.searchablespinnerlibrary.SearchableSpinner
                                android:id="@+id/spin_Tujuan"
                                android:layout_width="match_parent"
                                android:layout_height="30dp"
                                app:hintText="@string/hint_pilih_tujuan"
                                android:inputType="text"
                                android:layout_marginBottom="10dp"
                                android:drawablePadding="5dp"
                                android:textColor="#000"
                                android:drawableLeft="@drawable/ic_action_name"
                                android:nextFocusDown="@id/et_Koli"
                                />
                            <EditText
                                android:id="@+id/et_KodeTujuan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text=""
                                android:hint="Asal"
                                android:paddingStart="20dp"
                                android:textSize="13dp"
                                android:visibility="gone"
                                android:inputType="text"
                                />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                >

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:layout_marginRight="5dp"
                                    android:textSize="10dp"
                                    android:text="@string/jumlah_koli"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />

                                <TextView
                                    android:layout_width="1dp"
                                    android:layout_height="20dp"
                                    android:textSize="10dp"
                                    android:text="Satuan"
                                    android:visibility="gone"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />


                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:textSize="10dp"
                                    android:layout_marginRight="5dp"
                                    android:text="@string/berat_kg"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:textSize="10dp"
                                    android:text="@string/jumlah_kuantitas"
                                    android:paddingTop="4dp"
                                    android:paddingLeft="5dp"
                                    />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_gravity="center_horizontal"
                                >

                                <EditText
                                    android:id="@+id/et_Koli"
                                    android:layout_width="0dp"
                                    android:layout_height="40dp"
                                    android:layout_weight="1"
                                    android:hint="0"
                                    android:textSize="14dp"
                                    android:inputType="number"
                                    android:drawablePadding="5dp"
                                    android:layout_marginRight="5dp"
                                    android:textColor="#000"
                                    android:maxLength="4"
                                    android:drawableLeft="@drawable/ic_koli"
                                    android:nextFocusDown="@id/et_Berat"
                                    />


                                <EditText
                                    android:id="@+id/et_Berat"
                                    android:layout_width="0dp"
                                    android:layout_height="40dp"
                                    android:layout_weight="1"
                                    android:hint="0 Kg"
                                    android:textSize="14dp"
                                    android:inputType="number"
                                    android:drawablePadding="5dp"
                                    android:layout_marginRight="5dp"
                                    android:textColor="#000"
                                    android:maxLength="5"
                                    android:drawableLeft="@drawable/ic_berat1"
                                    android:nextFocusDown="@id/et_Kuantitas"
                                    />

                                <EditText
                                    android:id="@+id/et_Kuantitas"
                                    android:layout_width="0dp"
                                    android:layout_height="40dp"
                                    android:layout_weight="1"
                                    android:hint="0"
                                    android:textSize="14dp"
                                    android:inputType="number"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:maxLength="5"
                                    android:drawableLeft="@drawable/ic_kuantitas"
                                    android:nextFocusDown="@id/et_Deskripsi"
                                    />

                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="10dp"
                                android:text="@string/deskripsi"
                                android:paddingTop="4dp"
                                android:paddingLeft="5dp"
                                />

                            <EditText
                                android:id="@+id/et_Deskripsi"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_deskripsi"
                                android:textSize="14dp"
                                android:inputType="textMultiLine"
                                android:lines="3"
                                android:maxLines="6"
                                android:drawablePadding="5dp"
                                android:textColor="#000"
                                android:scrollbars="vertical"
                                android:drawableLeft="@drawable/ic_detail"
                                android:nextFocusDown="@drawable/blue_button_background"
                                />


                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ly_KodeDOdanTujuan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:paddingBottom="3dp">


                                <TextView
                                    android:id="@+id/txt_noDO"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.5"
                                    android:drawableLeft="@drawable/ic_invoice"
                                    android:text="Kode DO"
                                    android:gravity="left"
                                    android:textSize="15dp"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:visibility="visible"
                                    android:fontFamily="@font/roboto_bold" />

                                <TextView
                                    android:id="@+id/txt_Tujuan"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_bus"
                                    android:text="Tujuan DO"
                                    android:gravity="left"
                                    android:textSize="15dp"
                                    android:drawablePadding="5dp"
                                    android:textColor="#000"
                                    android:visibility="visible"
                                    android:fontFamily="@font/roboto_bold" />


                            </LinearLayout>


                        </LinearLayout>


                    </LinearLayout>

                </androidx.cardview.widget.CardView>


            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/ly_DaftarBarcode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:visibility="gone"
            >

            <LinearLayout
                android:id="@+id/scanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="2dp"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:fontFamily="@font/roboto_bold"
                            android:text="@string/cari_kode_qr"
                            android:textColor="@color/BLACK"
                            android:paddingStart="15dp"
                            android:textSize="15dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:fontFamily="@font/roboto_bold"
                            android:gravity="right"
                            android:text="@string/scanner"
                            android:textColor="@color/BLACK"
                            android:textSize="15dp" />
                        <TextView
                            android:id="@+id/hasilcari"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:fontFamily="@font/roboto_bold"
                            android:textColor="@color/BLACK"
                            android:visibility="gone"
                            android:textSize="15dp" />
                        <Switch
                            android:id="@+id/scan_QrCode"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginRight="15dp"
                            android:layout_weight="1"
                            android:checked="false"
                            android:gravity="center"
                            android:showText="false"
                            android:textOff="No"
                            android:textOn="Yes"
                            android:textSize="12sp"
                            android:thumb="@drawable/round_thumb"
                            android:track="@drawable/round_track" />

                    </LinearLayout>


                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/view_ScanQrCode"
                    android:layout_width="fill_parent"
                    android:layout_height="130dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:layout_marginRight="5dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="2dp"
                        app:cardCornerRadius="5dp"
                        app:cardElevation="5dp">

                        <com.journeyapps.barcodescanner.DecoratedBarcodeView
                            android:id="@+id/barcode_scanner"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                        </com.journeyapps.barcodescanner.DecoratedBarcodeView>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/scanner"
                android:layout_marginTop="5dp"
                >

                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                    android:id="@+id/swipe_refresh_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_daftar_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clipToPadding="false"
                            android:paddingBottom="90dp"
                            android:visibility="visible"
                            />

                        <TextView
                            android:id="@+id/tv_Kosong"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textSize="15sp"
                            android:text="Scan barcode barang yang akan dikirim !"
                            android:paddingBottom="200dp"
                            android:fontFamily="@font/roboto_bold"
                            android:visibility="visible"
                            android:layout_gravity="center"
                            android:gravity="center"
                            />

                    </LinearLayout>

                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_alignParentBottom="true"
        >

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_PilihKendaraan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="10dp"
            android:background="@drawable/blue_button_background"
            android:padding="12dp"
            android:text="Pilih"
            android:textColor="@android:color/white"
            android:layout_alignParentBottom="true"
            android:fontFamily="@font/roboto_bold"
            android:visibility="visible"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_SimpanDO"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="10dp"
            android:background="@drawable/blue_button_background"
            android:padding="12dp"
            android:text="Simpan Nomor DO"
            android:textColor="@android:color/white"
            android:layout_alignParentBottom="true"
            android:fontFamily="@font/roboto_bold"
            android:visibility="gone"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_UpdateStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="10dp"
            android:background="@drawable/blue_button_background"
            android:padding="12dp"
            android:text="Update Status OTW"
            android:textColor="@android:color/white"
            android:layout_alignParentBottom="true"
            android:fontFamily="@font/roboto_bold"
            android:visibility="gone"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_TambahNoDO"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="10dp"
            android:background="@drawable/blue_button_background"
            android:padding="12dp"
            android:text="Tambah DO Baru"
            android:textColor="@android:color/white"
            android:layout_alignParentBottom="true"
            android:fontFamily="@font/roboto_bold"
            android:visibility="gone"
            />


    </LinearLayout>

</RelativeLayout>