<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.dhs.Loading.DaftarLoadingDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="5dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/layout_Detail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:foreground="?android:attr/selectableItemBackgroundBorderless"
                            android:layout_marginBottom="2dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginBottom="2dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Nomor Transaksi"
                                    android:textSize="10dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Tanggal Transkasi"
                                    android:textSize="10dp" />


                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:paddingBottom="3dp">


                                <TextView
                                    android:id="@+id/txt_noTrans"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_invoice"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:fontFamily="@font/roboto_bold"
                                    android:textColor="#000"
                                    android:textSize="13dp" />

                                <TextView
                                    android:id="@+id/txt_transactionDate"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_date"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:textSize="13dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginBottom="2dp"
                                android:orientation="horizontal">




                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:paddingBottom="3dp">




                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginBottom="2dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Tanggal Loading"
                                    android:textSize="10dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Tanggal Unloading"
                                    android:textSize="10dp" />


                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:paddingBottom="3dp">


                                <TextView
                                    android:id="@+id/txt_TanggalStatusLoading"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_date"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:textSize="13dp" />

                                <TextView
                                    android:id="@+id/txt_TanggalStatusUnloading"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_date"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:textSize="13dp" />


                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginBottom="2dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Nomor Truck"
                                    android:textSize="10dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Nama Supir"
                                    android:textSize="10dp" />


                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:paddingBottom="3dp">


                                <TextView
                                    android:id="@+id/txt_noTruck"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_nomor_truck"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:textSize="13dp" />


                                <TextView
                                    android:id="@+id/txt_NamaSupir"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:gravity="center|left"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_pengguna"
                                    android:drawablePadding="5dp"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:textSize="13dp" />


                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginBottom="2dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Asal - Tujuan"
                                    android:textSize="10dp" />


                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:paddingBottom="3dp">


                                <TextView
                                    android:id="@+id/txt_asalTujuan"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_truck"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:textSize="13dp"
                                    />


                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginBottom="2dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Transit"
                                    android:textSize="10dp" />

                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:paddingBottom="3dp">


                                <TextView
                                    android:id="@+id/txt_transit"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.8"
                                    android:drawableLeft="@drawable/ic_transit"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:textSize="13dp"
                                    />



                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginBottom="2dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1.2"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Total Barcode"
                                    android:textSize="10dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1.2"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="Type Load"
                                    android:textSize="10dp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="1"
                                    android:paddingLeft="5dp"
                                    android:paddingTop="4dp"
                                    android:text="@string/status_kendaraan"
                                    android:textSize="10dp" />


                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:orientation="horizontal"
                                android:paddingBottom="3dp">

                                <TextView
                                    android:id="@+id/txt_TotalBarcdoe"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:layout_weight="1.2"
                                    android:drawableLeft="@drawable/ic_qr_code"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="0"
                                    android:textColor="#000"
                                    android:fontFamily="@font/roboto_bold"
                                    android:textSize="15dp" />

                                <TextView
                                    android:id="@+id/txt_LoadType"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:layout_weight="1.2"
                                    android:drawableLeft="@drawable/ic_label"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:fontFamily="@font/roboto_bold"
                                    android:textSize="13dp" />

                                <TextView
                                    android:id="@+id/txt_Status"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center_vertical"
                                    android:layout_weight="1"
                                    android:drawableLeft="@drawable/ic_status"
                                    android:drawablePadding="5dp"
                                    android:gravity="center|left"
                                    android:text="-"
                                    android:textColor="#000"
                                    android:fontFamily="@font/roboto_bold"
                                    android:textSize="13dp" />



                            </LinearLayout>


                        </LinearLayout>

                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_Detail_Barcode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/button_background_line_item"
                        android:fontFamily="@font/roboto_bold"
                        android:padding="3dp"
                        android:layout_marginHorizontal="15dp"
                        android:layout_marginTop="10dp"
                        android:text="Detail Barcode"
                        android:layout_marginBottom="15dp"
                        android:textAllCaps="false"
                        android:foreground="?android:attr/selectableItemBackgroundBorderless"
                        android:textColor="@android:color/black" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>


    </LinearLayout>

</RelativeLayout>