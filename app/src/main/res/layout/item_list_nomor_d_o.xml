<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    xmlns:sweet="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginLeft="6dp"
    android:layout_marginRight="6dp"
    android:layout_marginBottom="4dp"
    sweet:cardElevation="5dp"
    sweet:cardCornerRadius="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:orientation="vertical">

    <LinearLayout
        android:id="@+id/layout_Detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?android:attr/selectableItemBackgroundBorderless"
        android:layout_marginBottom="2dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="2dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"
                android:paddingLeft="5dp"
                android:paddingTop="4dp"
                android:text="@string/nomor_do"
                android:textSize="10dp" />


            <TextView
                android:id="@+id/title_asal"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"
                android:paddingLeft="5dp"
                android:paddingTop="4dp"
                android:textAlignment="center"
                android:text="@string/asal"
                android:textSize="10dp"
                android:visibility="gone"/>


            <TextView
                android:id="@+id/title_tujuan"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"
                android:paddingLeft="5dp"
                android:paddingTop="4dp"
                android:textAlignment="center"
                android:text="@string/tujuan"
                android:textSize="10dp"
                android:visibility="gone"/>


            <TextView
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"
                android:paddingLeft="5dp"
                android:paddingTop="4dp"
                android:text="@string/status_kendaraan"
                android:textAlignment="textEnd"
                android:textSize="10dp" />



        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:paddingBottom="3dp">


            <TextView
                android:id="@+id/txt_noDO"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableLeft="@drawable/ic_truck"
                android:drawablePadding="5dp"
                android:gravity="center|left"
                android:text="Nomor DO"
                android:textColor="#000"
                android:textSize="13dp" />

            <FrameLayout
                android:id="@+id/fl_Asal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:visibility="gone"
                >

                <TextView
                    android:id="@+id/txt_Asal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_bus"
                    android:text="Asal"
                    android:textColor="#000"
                    android:drawablePadding="5dp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:textSize="13dp"
                    />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/fl_Tujuan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:visibility="gone"
                >

                <TextView
                    android:id="@+id/txt_Tujuan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawableLeft="@drawable/ic_bus"
                    android:text="Tujuan"
                    android:textColor="#000"
                    android:drawablePadding="5dp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:textSize="13dp" />

            </FrameLayout>


            <TextView
                android:id="@+id/txt_StatusKendaraan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:drawableRight="@drawable/ic_status"
                android:drawablePadding="5dp"
                android:gravity="center|right"
                android:text="Status"
                android:textColor="#000"
                android:textSize="13dp" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="5dp"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity=""
                android:paddingBottom="2dp"
                >

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10dp"
                    android:text="Jumlah Koli"
                    android:paddingTop="4dp"
                    android:textAlignment="center"
                    />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10dp"
                    android:text="@string/berat_kg"
                    android:paddingTop="4dp"
                    android:paddingLeft="5dp"
                    android:textAlignment="center"
                    />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10dp"
                    android:text="@string/jumlah_kuantitas"
                    android:paddingTop="4dp"
                    android:paddingLeft="5dp"
                    android:textAlignment="center"
                    />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10dp"
                    android:text="@string/total_qr_code"
                    android:paddingTop="4dp"
                    android:paddingLeft="5dp"
                    android:textAlignment="center"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >

                <TextView
                    android:id="@+id/txt_Koli"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#000"
                    android:textSize="13dp"
                    android:text="0"
                    android:textAlignment="center"
                    android:paddingLeft="5dp" />

                <TextView
                    android:id="@+id/txt_Berat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#000"
                    android:textSize="13dp"
                    android:text="0"
                    android:textAlignment="center"
                    android:paddingLeft="5dp"
                    />

                <TextView
                    android:id="@+id/txt_Kuantitas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#000"
                    android:textSize="13dp"
                    android:text="0"
                    android:textAlignment="center"
                    android:paddingLeft="5dp"
                    />

                <TextView
                    android:id="@+id/txt_TotalQrCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#000"
                    android:textSize="13dp"
                    android:text="0"
                    android:textAlignment="center"
                    android:paddingLeft="5dp"
                    />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.2dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"
            android:background="#888888"
            android:visibility="visible" />

        <LinearLayout
            android:id="@+id/ly_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless">

                    <Button
                        android:id="@+id/btn_ScanDetailDo"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:background="@null"
                        android:drawableLeft="@drawable/ic_qr_code1"
                        android:drawablePadding="2dp"
                        android:foreground="?android:attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingLeft="10dp"
                        android:paddingTop="7dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="7dp"
                        android:text="@string/daftar_scan_do"
                        android:textAllCaps="false"
                        android:textColor="#555"
                        android:textSize="12dp" />
                </FrameLayout>


            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
