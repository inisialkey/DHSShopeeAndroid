<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/grey"
    android:layout_height="match_parent"
    tools:context=".activity.dhs.Loading.DaftarLoadingActivity">

    <LinearLayout
        android:id="@+id/filterData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:paddingTop="5dp"
        android:visibility="gone"
        >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            app:cardCornerRadius="5dp"
            app:cardElevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal"
                >


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:orientation="vertical"
                    android:padding="5dp"
                    >


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:layout_gravity="center_horizontal"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="20dp"
                            android:layout_weight="1"
                            android:textSize="10dp"
                            android:text="@string/tanggal_awal"
                            android:paddingTop="4dp"
                            android:paddingLeft="5dp"
                            />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="20dp"
                            android:layout_weight="1"
                            android:textSize="10dp"
                            android:text="@string/tanggal_akhir"
                            android:paddingTop="4dp"
                            android:paddingLeft="5dp"
                            />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="5dp"
                        android:layout_gravity="center_horizontal"
                        >

                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:layout_weight="1"
                            android:drawablePadding="5dp"
                            >

                            <EditText
                                android:id="@+id/dt1awal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusableInTouchMode="true"
                                android:hint="@string/tanggal_awal"
                                android:inputType="text"
                                android:paddingLeft="5dp"
                                android:paddingTop="4dp"
                                android:text="@string/tanggal_awal"
                                android:textColor="#000"
                                android:textSize="12dp"
                                android:layout_marginRight="25dp"
                                />

                            <ImageButton
                                android:id="@+id/dt1"
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:onClick="setDate"
                                android:background="@drawable/ic_date"
                                android:layout_alignParentRight="true"
                                />

                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:layout_weight="1"
                            android:drawablePadding="5dp"
                            >

                            <EditText
                                android:id="@+id/dt2akhir"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusableInTouchMode="true"
                                android:hint="@string/tanggal_akhir"
                                android:inputType="text"
                                android:paddingLeft="5dp"
                                android:paddingTop="4dp"
                                android:text="@string/tanggal_akhir"
                                android:textColor="#000"
                                android:textSize="12dp"
                                android:layout_marginRight="25dp"
                                />

                            <ImageButton
                                android:id="@+id/dt2"
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:onClick="setDate2"
                                android:background="@drawable/ic_date"
                                android:layout_alignParentRight="true"
                                />

                        </RelativeLayout>

                        <TextView
                            android:id="@+id/dt3send"
                            android:layout_width="1dp"
                            android:layout_height="1dp"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

                <ImageButton
                    android:id="@+id/refresh"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/colorPrimary"
                    android:onClick="setRefresh"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_refresh_white" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:layout_below="@id/filterData"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_daftar_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingBottom="90dp"
                android:layout_marginRight="5dp"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="5dp"
                />

            <TextView
                android:id="@+id/tv_Kosong"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textSize="16sp"
                android:paddingBottom="200dp"
                android:fontFamily="@font/roboto_bold"
                android:visibility="visible"
                android:layout_gravity="center"
                android:gravity="center"
                />

        </LinearLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_TambahKendaraan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_add"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:layout_marginRight="25dp"
        android:layout_marginBottom="35dp"
        app:fabSize="auto"
        android:backgroundTint="@color/colorPrimaryDark"
        android:visibility="visible"
        />

</RelativeLayout>