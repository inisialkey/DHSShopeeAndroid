<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.login.AktivasiAkunActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_above="@+id/tombol">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="5dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    >

                    <!--Nama-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="12dp"
                            android:text="Nama Pengguna atau Email atau Nomor Hp"
                            android:paddingTop="4dp"
                            android:paddingLeft="5dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginBottom="10dp"
                        >

                        <EditText
                            android:id="@+id/et_Akun"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:drawableLeft="@drawable/ic_pengguna"
                            android:drawablePadding="5dp"
                            android:hint="Masukan disini"
                            android:inputType="text"
                            android:textColor="#000"
                            android:textSize="14dp" />

                    </LinearLayout>


                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginTop="10dp"
                        android:padding="10dp"
                        >

                        <FrameLayout
                            android:id="@+id/btn_Aktivasi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <Button
                                android:id="@+id/btn_CekAkun"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/button_background_line_orange"
                                android:fontFamily="@font/roboto_bold"
                                android:padding="12dp"
                                android:text="Cek Akun"
                                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                                android:textColor="@android:color/black" />

                            <ProgressBar
                                android:id="@+id/progressBar"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center"
                                android:visibility="gone"/>


                        </FrameLayout>

                        <LinearLayout
                            android:id="@+id/ly_Login"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingTop="10dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_below="@+id/btn_Aktivasi"
                            android:layout_marginBottom="10dp"
                            >

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginRight="10dp"
                                android:textSize="12dp"
                                android:text="@string/sudah_punya_akun"
                                android:paddingTop="4dp"
                                android:paddingLeft="5dp"
                                android:gravity="center"
                                />

                            <TextView
                                android:id="@+id/txt_Login"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="14dp"
                                android:text="@string/masuk"
                                android:paddingTop="4dp"
                                android:paddingLeft="5dp"
                                android:fontFamily="@font/roboto_bold"
                                android:textColor="@color/red"
                                android:gravity="center"
                                />
                        </LinearLayout>

                    </RelativeLayout>


                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="5dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    >

                    <!--Title-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginVertical="10dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="17dp"
                            android:text="Informasi Akun"
                            android:paddingTop="4dp"
                            android:paddingLeft="5dp"
                            android:fontFamily="@font/roboto_bold"

                            />
                    </LinearLayout>

                    <!--Nama-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:layout_margin="10dp"
                        >

                        <TextView
                            android:id="@+id/txt_IdAkun"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone"
                            android:drawableLeft="@drawable/ic_pengguna"
                            />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nama Pengguna"
                            android:textSize="14dp"
                            android:gravity="center|left"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:drawableLeft="@drawable/ic_pengguna"
                            />

                        <TextView
                            android:id="@+id/txt_NamaPengguna"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:text=""
                            android:fontFamily="@font/roboto_bold"
                            android:textSize="14dp"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:gravity="center|right"
                            android:layout_gravity="center"
                            />

                    </LinearLayout>

                    <!--Email-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:layout_margin="10dp"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Email"
                            android:textSize="14dp"
                            android:gravity="center|left"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:drawableLeft="@drawable/ic_email"
                            />

                        <TextView
                            android:id="@+id/txt_Email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text=""
                            android:fontFamily="@font/roboto_bold"
                            android:textSize="14dp"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:gravity="center|right"
                            android:layout_gravity="center"
                            />

                    </LinearLayout>

                    <!--Nomor Hp-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:layout_margin="10dp"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nomor Hp"
                            android:textSize="14dp"
                            android:gravity="center|left"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:drawableLeft="@drawable/ic_phone_01"
                            />

                        <TextView
                            android:id="@+id/txt_NomorHp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_weight="1.5"
                            android:drawablePadding="5dp"
                            android:fontFamily="@font/roboto_bold"
                            android:gravity="center|right"
                            android:text=""
                            android:textColor="#000"
                            android:textSize="14dp" />

                    </LinearLayout>

                    <!--Nomor Hp-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:layout_margin="10dp"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Daftar Melalui"
                            android:textSize="14dp"
                            android:gravity="center|left"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:drawableLeft="@drawable/ic_status"
                            />

                        <TextView
                            android:id="@+id/txt_AktivasiBy"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_weight="1.5"
                            android:drawablePadding="5dp"
                            android:fontFamily="@font/roboto_bold"
                            android:gravity="center|right"
                            android:text=""
                            android:textColor="#000"
                            android:textSize="14dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:orientation="vertical"
                        >

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cv_cardAkun"
                            android:layout_width="match_parent"
                            android:layout_height="35dp"
                            android:layout_marginHorizontal="10dp"
                            android:layout_marginTop="15dp"
                            android:layout_marginBottom="5dp"
                            app:cardCornerRadius="5dp"
                            app:cardBackgroundColor="#BCB8B7"
                            >

                            <TextView
                                android:id="@+id/status_Akun"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:fontFamily="@font/roboto_bold"
                                android:gravity="center"
                                android:text="Belum ada akun"
                                android:textColor="@color/white" />

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cv_cardAkun1"
                            android:layout_width="match_parent"
                            android:layout_height="35dp"
                            android:layout_marginHorizontal="10dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="5dp"
                            app:cardCornerRadius="5dp"
                            app:cardBackgroundColor="#BCB8B7"
                            android:visibility="gone"
                            >

                            <TextView
                                android:id="@+id/status_Akun1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:fontFamily="@font/roboto_bold"
                                android:gravity="center"
                                android:text="Belum ada akun"
                                android:textColor="@color/white" />

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/ly_textWarning01"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="10dp"
                    android:layout_marginHorizontal="20dp"
                    android:paddingBottom="5dp"
                    android:gravity="center"
                    android:fontFamily="@font/roboto_medium"
                    android:textColor="@color/red"
                    android:text="Akun anda akan aktif jika sudah di approval oleh super admin, mohon tunggu !"
                    />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/tombol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:layout_alignParentBottom="true"
        >

        <FrameLayout
            android:id="@+id/fl_Register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/buttonGetOTP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_background_line_biru"
                android:fontFamily="@font/roboto_bold"
                android:padding="12dp"
                android:text="Konfirmasi Registrasi"
                android:textAllCaps="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:textColor="@android:color/black" />

            <ProgressBar
                android:id="@+id/progressBar1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone"/>


        </FrameLayout>

    </RelativeLayout>

</RelativeLayout>