<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.login.PeringatanAkunActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:gravity="center"
        android:layout_above="@+id/text_Warning01">

        <ImageView
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:src="@drawable/icon_konfirmasi_registrasi"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/text_Warning01"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_bold"
                    android:text="AKUN ANDA BERHASIL REGISTRASI"
                    android:textAlignment="center"
                    android:textColor="#292828"
                    android:textSize="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="15dp"
                    android:text="Untuk masuk (login), akun anda harus menunggu approval dari super admin terlebih dahulu"
                    android:textAlignment="center"
                    android:fontFamily="@font/roboto_medium"
                    />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:paddingHorizontal="15dp"
                    android:text="Saat ini akun anda (BELUM AKTIF)"
                    android:textAlignment="center"
                    android:textSize="14dp"
                    android:textColor="@color/red"
                    android:fontFamily="@font/roboto_bold"
                    />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingHorizontal="15dp"
                    android:text="Informasi akun anda dapat di-cek pada halaman login (Konfirmasi registrasi)"
                    android:textAlignment="center"
                    android:fontFamily="@font/roboto_regular"
                    android:layout_marginBottom="20dp"
                    />



            </LinearLayout>

        </androidx.cardview.widget.CardView>



    </LinearLayout>

    <LinearLayout
        android:id="@+id/tombol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        >

        <FrameLayout
            android:id="@+id/fl_Register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_background"
                android:fontFamily="@font/roboto_bold"
                android:padding="12dp"
                android:text="Masuk"
                android:textAllCaps="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:textColor="@android:color/white" />

            <ProgressBar
                android:id="@+id/progressBar1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone"/>


        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/daftar"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Daftar"
                android:textSize="15dp"
                android:textColor="@color/blues"
                android:fontFamily="@font/roboto_bold"/>

            <TextView
                android:id="@+id/konfirmasi"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Konfirmasi Registrasi"
                android:textSize="14dp"
                android:textColor="@color/orange"
                android:fontFamily="@font/roboto_bold"/>


        </LinearLayout>

    </LinearLayout>

</RelativeLayout>