<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.dhs.Loading.TambahBarcodeManualActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_above="@id/button">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                app:cardCornerRadius="5dp"
                app:cardElevation="5dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="15dp"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Barcode manual"
                            android:paddingTop="4dp"
                            android:drawablePadding="5dp"
                            android:paddingLeft="5dp"
                            android:layout_gravity="center|left"
                            android:fontFamily="@font/roboto_regular"
                            android:textSize="14dp"
                            />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ly_textWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:visibility="gone"
                        >

                        <TextView
                            android:id="@+id/text_Warning02"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="* Setelah disimpan maka akan ditandai warna biru"
                            android:drawablePadding="5dp"
                            android:paddingLeft="5dp"
                            android:layout_gravity="center|left"
                            android:fontFamily="@font/roboto_regular"
                            android:textSize="10dp"
                            android:textColor="#E91E63"
                            />

                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/lyUangBayar1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:paddingBottom="5dp"
                        android:visibility="visible"
                        >

                        <EditText
                            android:id="@+id/et_BarcodeManual"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_weight="1"
                            android:layout_marginRight="10dp"
                            android:textSize="16dp"
                            android:inputType="text"
                            android:drawablePadding="10dp"
                            android:textColor="#000"
                            android:drawableLeft="@drawable/ic_qr_code"
                            android:gravity="center|left"
                            android:hint="Masukan Barcode Disini"
                            />


                    </LinearLayout>

                </LinearLayout>



            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_chekBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="5dp"
                app:cardCornerRadius="5dp"
                app:cardElevation="5dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:fontFamily="@font/roboto_bold"
                        android:text="Tambahkan Gambar"
                        android:textColor="@color/BLACK"
                        android:paddingStart="15dp"
                        android:textSize="15dp" />

                    <TextView
                        android:id="@+id/txt_chekBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:fontFamily="@font/roboto_bold"
                        android:gravity="right"
                        android:text="Tidak"
                        android:textColor="@color/BLACK"
                        android:textSize="15dp" />
                    <TextView
                        android:id="@+id/hasilcari"
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:fontFamily="@font/roboto_bold"
                        android:textColor="@color/BLACK"
                        android:visibility="gone"
                        android:textSize="15dp" />
                    <Switch
                        android:id="@+id/checkbox_Switch"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginRight="15dp"
                        android:layout_weight="1"
                        android:checked="false"
                        android:gravity="center"
                        android:showText="false"
                        android:textOff="No"
                        android:textOn="Yes"
                        android:textSize="12sp"
                        android:thumb="@drawable/round_thumb"
                        android:track="@drawable/round_track" />

                </LinearLayout>


            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_foto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="3dp"
                app:cardCornerRadius="5dp"
                app:cardElevation="5dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="15dp"
                    >

                    <LinearLayout
                        android:id="@+id/ly_textWarning01"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:layout_gravity="center_horizontal"
                        >

                        <TextView
                            android:id="@+id/text_Warning01"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="* Gambar akan langsung di di simpan"
                            android:drawablePadding="5dp"
                            android:paddingLeft="5dp"
                            android:layout_gravity="center|left"
                            android:fontFamily="@font/roboto_regular"
                            android:textSize="10dp"
                            android:textColor="#E91E63"
                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.github.chrisbanes.photoview.PhotoView
                            android:id="@+id/displayImageView"
                            android:layout_width="300dp"
                            android:layout_height="310dp"
                            android:layout_marginHorizontal="5dp"
                            android:background="@color/grey"
                            app:srcCompat="@drawable/ic_gallery"/>

                        <!--<ImageView
                            android:id="@+id/displayImageView"
                            android:layout_width="300dp"
                            android:layout_height="300dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/bgblue"
                            app:srcCompat="@drawable/ic_gallery" />-->

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            >

                            <!--<Button
                                android:id="@+id/cameraBtn"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_margin="10dp"
                                android:text="Kamera"
                                android:drawableTop="@drawable/ic_kamera"
                                android:paddingVertical="5dp"
                                android:textColor="#FFF"
                                android:background="@drawable/button_background_dsbl"
                                />

                            <Button
                                android:id="@+id/galleryBtn"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_margin="10dp"
                                android:drawableTop="@drawable/ic_gallery"
                                android:paddingVertical="5dp"
                                android:text="Gallery"
                                android:textColor="#FFF"
                                android:background="@drawable/button_background_dsbl"
                                />-->

                        </LinearLayout>

                    </LinearLayout>



                </LinearLayout>



            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/ly_textWarning02"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="#E91E63"
                    android:textSize="12dp"
                    android:text="*"
                    />

                <TextView
                    android:id="@+id/text_Warning03"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="4dp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="#E91E63"
                    android:textSize="12dp"
                    android:paddingRight="10dp"
                    android:text="Ketika pilih kamera atau gallery barcode manual dan foto akan langsung tersimpan"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginVertical="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="#E91E63"
                    android:textSize="12dp"
                    android:text="*"
                    />

                <TextView
                    android:id="@+id/text_Warning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="4dp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="#E91E63"
                    android:textSize="12dp"
                    android:paddingRight="10dp"
                    android:text="Barcode manual setelah disimpan maka akan ditandai warna biru"
                    />

            </LinearLayout>


            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible"
                />


        </LinearLayout>

    </androidx.core.widget.NestedScrollView>






    <LinearLayout
        android:id="@+id/button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_alignParentBottom="true"
        android:padding="2dp"
        >

        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:visibility="gone"
            android:layout_gravity="center"
            android:background="@drawable/blue_button_background"
            android:text="Simpan"
            android:textColor="@android:color/white"
            android:fontFamily="@font/roboto_bold"
            android:drawableTop="@drawable/ic_save"
            android:paddingVertical="5dp"
            android:layout_margin="10dp"
            />

        <Button
            android:id="@+id/cameraBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="10dp"
            android:text="Kamera"
            android:drawableTop="@drawable/ic_kamera"
            android:paddingVertical="5dp"
            android:textColor="#FFF"
            android:background="@drawable/blue_button_background"
            />

        <Button
            android:id="@+id/galleryBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="10dp"
            android:drawableTop="@drawable/ic_gallery"
            android:paddingVertical="5dp"
            android:text="Gallery"
            android:textColor="#FFF"
            android:background="@drawable/button_background_dsbl"
            />

    </LinearLayout>

</RelativeLayout>