<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.fungsitama.dhsshopee.activity.login.ActivationRegsiterActivity">

    <ImageView
        android:id="@+id/logo"
        android:layout_width="130dp"
        android:layout_height="120dp"
        android:background="@drawable/icon_send_verify"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="20dp"
        android:visibility="visible"
        android:layout_centerHorizontal="true"
        />

    <LinearLayout
        android:id="@+id/ly_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:orientation="vertical"
        android:layout_below="@id/logo"
        >

        <TextView
            android:id="@+id/txt_Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/title_aktivasi"
            android:textAlignment="center"
            android:textColor="#292828"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/txt_SubTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_aktivasi"
            android:textAlignment="center"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="10dp"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_email_token"
                android:fontFamily="@font/roboto_regular"
                />

            <TextView
                android:id="@+id/txt_Email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="nama@email.com"
                android:fontFamily="@font/roboto_bold"
                />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="15dp"
            >

            <TextView
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"
                android:text="@string/subtitle_email_token"
                android:textAlignment="viewEnd"
                android:fontFamily="@font/roboto_regular"
                />


            <TextView
                android:id="@+id/txt_Token"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/kirim_ulang_token"
                android:textColor="#4CAF50"
                android:paddingLeft="10dp"
                android:textAllCaps="true"
                />
        </LinearLayout>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/formRegsiter"
        android:layout_below="@+id/ly_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    >

                    <!--Nama-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        >

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="12dp"
                            android:text="Kode OTP"
                            android:paddingTop="4dp"
                            android:paddingLeft="5dp"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        >

                        <EditText
                            android:id="@+id/et_Token"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/masukan_token"
                            android:textSize="14dp"
                            android:inputType="text"
                            android:drawablePadding="5dp"
                            android:textColor="#000"
                            android:drawableLeft="@drawable/ic_smu"
                            />

                    </LinearLayout>



                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        >

                        <Button
                            android:id="@+id/btn_Aktivasi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/button_yellow"
                            android:padding="12dp"
                            android:text="@string/aktivasi"
                            android:layout_marginTop="40dp"
                            android:textColor="@android:color/white"
                            android:fontFamily="@font/roboto_bold"
                            />

                        <LinearLayout
                            android:id="@+id/ly_Login"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingTop="10dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_below="@+id/btn_Aktivasi"
                            android:layout_marginBottom="10dp"
                            >

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginRight="10dp"
                                android:textSize="12dp"
                                android:text="@string/sudah_punya_akun"
                                android:paddingTop="4dp"
                                android:paddingLeft="5dp"
                                android:gravity="center"
                                />

                            <TextView
                                android:id="@+id/txt_Login"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="14dp"
                                android:text="@string/masuk"
                                android:paddingTop="4dp"
                                android:paddingLeft="5dp"
                                android:fontFamily="@font/roboto_bold"
                                android:textColor="@color/red"
                                android:gravity="center"
                                />
                        </LinearLayout>

                    </RelativeLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</RelativeLayout>