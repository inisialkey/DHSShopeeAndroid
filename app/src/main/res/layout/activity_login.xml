<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    xmlns:sweet="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey"
    android:orientation="vertical"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingTop="100dp"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingBottom="@dimen/activity_vertical_margin">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="10"
        android:orientation="vertical"
        android:weightSum="10">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1.6"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="15dp"
            >
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="DHS"
                android:textStyle="italic"
                android:textColor="@color/red"
                android:visibility="gone"
                android:textSize="50dp"/>
            <ImageView
                android:layout_width="200dp"
                android:layout_height="90dp"
                android:background="@drawable/logodhs01"
                android:visibility="visible"
                />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2.8"
            android:orientation="vertical"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="8">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="1dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:layout_weight="8">

                    <EditText
                        android:id="@+id/editTextUser"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_insert_emoticon_black_24dp"
                        android:drawablePadding="16dp"
                        android:fontFamily="@font/roboto_regular"
                        android:hint="@string/nama_pengguna"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textSize="18dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/next"
                    android:visibility="invisible"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:backgroundTint="@color/colorPrimary"
                    android:src="@android:drawable/ic_menu_send" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="8">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="1dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:layout_weight="8"
                    sweet:passwordToggleEnabled="true">

                    <EditText
                        android:id="@+id/editTextPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_vpn_key_black_24dp"
                        android:drawablePadding="16dp"
                        android:fontFamily="@font/roboto_regular"
                        android:hint="@string/kata_sandi"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textSize="18dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/next2"
                    android:visibility="invisible"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:backgroundTint="@color/colorPrimary"
                    android:src="@android:drawable/ic_menu_send" />
            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.1"
            >

            <TextView
                android:id="@+id/txtimei"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textSize="30dp"
                android:visibility="gone"/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3.1"
            android:gravity="bottom"
            >

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="220dp"
                android:layout_height="180dp"
                android:src="@drawable/image_login01"
                android:visibility="visible"
                android:layout_marginTop="10dp"
                />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2.4"
            >

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/buttonSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_yellow"
                    android:padding="12dp"
                    android:text="@string/daftar"
                    android:onClick="startRegistrasi"
                    android:textColor="@android:color/white"
                    android:layout_alignParentBottom="true"
                    android:fontFamily="@font/roboto_bold"
                    />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/buttonLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/button_background"
                    android:padding="12dp"
                    android:text="@string/masuk"
                    android:onClick="startLogin"
                    android:textColor="@android:color/white"
                    android:layout_above="@id/buttonSignUp"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/roboto_bold"
                    />

                <TextView
                    android:id="@+id/btntext_Aktivasi"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Konfirmasi Registrasi ?"
                    android:layout_marginEnd="8dp"
                    android:gravity="center|right"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="#FF5722"
                    android:layout_above="@id/buttonLogin"
                    android:padding="5dp"
                    android:onClick="text_Aktivasi"
                    />

            </RelativeLayout>

        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:text="Andika Pratama Logistic"
                android:textStyle="bold"
                />

        </LinearLayout>


    </LinearLayout>

</LinearLayout>
